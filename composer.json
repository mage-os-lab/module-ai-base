{
    "name": "mage-os/module-ai-base",
    "description": "Base AI module for Mage-OS — register and retrieve configuration for multiple AI backends.",
    "type": "magento2-module",
    "license": ["OSL-3.0", "AFL-3.0"],
    "authors": [
        { "name": "David Lambauer", "email": "david@run-as-root.sh" }
    ],
    "support": {
        "issues": "https://github.com/mage-os-lab/module-ai-base/issues",
        "source": "https://github.com/mage-os-lab/module-ai-base"
    },
    "repositories": {
        "mage-os-mirror": {
            "type": "composer",
            "url": "https://mirror.mage-os.org/"
        },
        "mage-os": {
            "type": "composer",
            "url": "https://repo.mage-os.org/"
        }
    },
    "require": {
        "php": "^8.2",
        "magento/framework": "^103.0 || ^104.0",
        "magento/module-backend": "^102.0 || ^103.0",
        "magento/module-config": "^101.2 || ^102.0",
        "magento/module-store": "^101.1 || ^102.0"
    },
    "suggest": {
        "symfony/ai-platform": "Unified client layer used by the bundled AiClientInterface adapter (experimental component; pin the version and verify compatibility with your Magento/Mage-OS release)"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "magento/magento-coding-standard": "*"
    },
    "autoload": {
        "files": ["src/registration.php"],
        "psr-4": { "MageOS\\AiBase\\": "src/" },
        "exclude-from-classmap": ["src/registration.php"]
    },
    "autoload-dev": {
        "psr-4": { "MageOS\\AiBase\\Test\\": "Test/" }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "magento/composer-dependency-version-audit-plugin": true,
            "magento/composer-root-update-plugin": true
        }
    }
}
