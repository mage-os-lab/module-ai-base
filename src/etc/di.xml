<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <preference for="MageOS\AiBase\Api\AiServiceSelectorInterface" type="MageOS\AiBase\Model\AiServiceSelector"/>
    <preference for="MageOS\AiBase\Api\Data\AiServiceInterface" type="MageOS\AiBase\Model\AiService"/>
    <preference for="MageOS\AiBase\Api\Data\FieldDescriptorInterface" type="MageOS\AiBase\Model\FieldDescriptor"/>
    <preference for="MageOS\AiBase\Api\AiClientFactoryInterface" type="MageOS\AiBase\Model\Client\ClientFactory"/>

    <!-- Symfony AI provider bridges (soft dependency: FQCN strings, resolved only when a client is created).
         Verified against symfony/ai-platform v0.11.0. xAI (Grok) has no dedicated bridge yet; register one
         here (or via a consumer module) once available upstream. -->
    <type name="MageOS\AiBase\Model\Client\ClientFactory">
        <arguments>
            <argument name="platformFactories" xsi:type="array">
                <item name="anthropic" xsi:type="string">Symfony\AI\Platform\Bridge\Anthropic\Factory</item>
                <item name="azure" xsi:type="string">Symfony\AI\Platform\Bridge\Azure\OpenAi\Factory</item>
                <item name="deepseek" xsi:type="string">Symfony\AI\Platform\Bridge\DeepSeek\Factory</item>
                <item name="google" xsi:type="string">Symfony\AI\Platform\Bridge\Gemini\Factory</item>
                <item name="huggingface" xsi:type="string">Symfony\AI\Platform\Bridge\HuggingFace\Factory</item>
                <item name="lmstudio" xsi:type="string">Symfony\AI\Platform\Bridge\LmStudio\Factory</item>
                <item name="ollama" xsi:type="string">Symfony\AI\Platform\Bridge\Ollama\Factory</item>
                <item name="openrouter" xsi:type="string">Symfony\AI\Platform\Bridge\OpenRouter\Factory</item>
                <item name="openai" xsi:type="string">Symfony\AI\Platform\Bridge\OpenAi\Factory</item>
            </argument>
        </arguments>
    </type>

    <!-- The sensitive-data processor decides field sensitivity from the same provider
         field schema the admin form renders; keep this item list in sync with the
         Block\Adminhtml\Configuration\Services "services" argument below. -->
    <type name="MageOS\AiBase\Model\Config\SensitiveDataProcessor">
        <arguments>
            <argument name="services" xsi:type="array">
                <item name="anthropic" xsi:type="object">MageOS\AiBase\AiServices\Anthropic</item>
                <item name="azure" xsi:type="object">MageOS\AiBase\AiServices\Azure</item>
                <item name="deepseek" xsi:type="object">MageOS\AiBase\AiServices\Deepseek</item>
                <item name="google" xsi:type="object">MageOS\AiBase\AiServices\Google</item>
                <item name="huggingface" xsi:type="object">MageOS\AiBase\AiServices\HuggingFace</item>
                <item name="lmstudio" xsi:type="object">MageOS\AiBase\AiServices\LmStudio</item>
                <item name="ollama" xsi:type="object">MageOS\AiBase\AiServices\Ollama</item>
                <item name="openrouter" xsi:type="object">MageOS\AiBase\AiServices\OpenRouter</item>
                <item name="openai" xsi:type="object">MageOS\AiBase\AiServices\OpenAi</item>
                <item name="xai" xsi:type="object">MageOS\AiBase\AiServices\Xai</item>
            </argument>
        </arguments>
    </type>

    <type name="MageOS\AiBase\Block\Adminhtml\Configuration\Services">
        <arguments>
            <argument name="services" xsi:type="array">
                <item name="anthropic" xsi:type="object">MageOS\AiBase\AiServices\Anthropic</item>
                <item name="azure" xsi:type="object">MageOS\AiBase\AiServices\Azure</item>
                <item name="deepseek" xsi:type="object">MageOS\AiBase\AiServices\Deepseek</item>
                <item name="google" xsi:type="object">MageOS\AiBase\AiServices\Google</item>
                <item name="huggingface" xsi:type="object">MageOS\AiBase\AiServices\HuggingFace</item>
                <item name="lmstudio" xsi:type="object">MageOS\AiBase\AiServices\LmStudio</item>
                <item name="ollama" xsi:type="object">MageOS\AiBase\AiServices\Ollama</item>
                <item name="openrouter" xsi:type="object">MageOS\AiBase\AiServices\OpenRouter</item>
                <item name="openai" xsi:type="object">MageOS\AiBase\AiServices\OpenAi</item>
                <item name="xai" xsi:type="object">MageOS\AiBase\AiServices\Xai</item>
            </argument>
        </arguments>
    </type>

    <!-- Refresh Models controller receives the same backend definitions as the admin form block;
         backends implementing Api\ModelListProviderInterface opt in to the live refresh. -->
    <type name="MageOS\AiBase\Controller\Adminhtml\Service\RefreshModels">
        <arguments>
            <argument name="services" xsi:type="array">
                <item name="anthropic" xsi:type="object">MageOS\AiBase\AiServices\Anthropic</item>
                <item name="azure" xsi:type="object">MageOS\AiBase\AiServices\Azure</item>
                <item name="deepseek" xsi:type="object">MageOS\AiBase\AiServices\Deepseek</item>
                <item name="google" xsi:type="object">MageOS\AiBase\AiServices\Google</item>
                <item name="huggingface" xsi:type="object">MageOS\AiBase\AiServices\HuggingFace</item>
                <item name="lmstudio" xsi:type="object">MageOS\AiBase\AiServices\LmStudio</item>
                <item name="ollama" xsi:type="object">MageOS\AiBase\AiServices\Ollama</item>
                <item name="openrouter" xsi:type="object">MageOS\AiBase\AiServices\OpenRouter</item>
                <item name="openai" xsi:type="object">MageOS\AiBase\AiServices\OpenAi</item>
                <item name="xai" xsi:type="object">MageOS\AiBase\AiServices\Xai</item>
            </argument>
        </arguments>
    </type>
</config>
