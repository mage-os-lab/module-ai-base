<?php
/** @var \Magento\Framework\Escaper $escaper */
/** @var \Magento\Framework\View\Helper\SecureHtmlRenderer $secureRenderer */
/** @var \MageOS\AiBase\Block\Adminhtml\Configuration\Services $block */

$_htmlId = $block->getHtmlId() ?: '_' . uniqid();
$_colspan = $block->isAddAfter() ? 2 : 1;
?>
<div class="ai-services-configurator design_theme_ua_regexp" id="grid<?= $escaper->escapeHtmlAttr($_htmlId) ?>">
    <div class="admin__control-table-wrapper">
        <table class="admin__control-table" id="<?= $escaper->escapeHtmlAttr($block->getElement()->getId()) ?>">
            <thead>
                <tr>
                    <?php foreach ($block->getColumns() as $column): ?>
                        <th><?= $escaper->escapeHtml($column['label']) ?></th>
                    <?php endforeach; ?>
                    <th class="col-actions" colspan="<?= (int) $_colspan ?>">
                        <?= $escaper->escapeHtml(__('Action')) ?>
                    </th>
                </tr>
            </thead>
            <tfoot>
                <tr>
                    <td colspan="<?= count($block->getColumns()) + $_colspan ?>" class="col-actions-add">
                        <ul>
                            <?php foreach ($block->getServicesButtons() as $button): ?>
                                <li data-ai-service="<?= $escaper->escapeHtmlAttr($button['code']) ?>"
                                    class="add-ai-service ai-service-<?= $escaper->escapeHtmlAttr($button['code']) ?>">
                                    <?= $escaper->escapeHtml($button['name']) ?>
                                </li>
                            <?php endforeach; ?>
                        </ul>
                    </td>
                </tr>
            </tfoot>
            <tbody id="addRow<?= $escaper->escapeHtmlAttr($_htmlId) ?>"></tbody>
        </table>
    </div>
    <input type="hidden"
           name="<?= $escaper->escapeHtmlAttr($block->getElement()->getName()) ?>[__empty]"
           value=""/>

    <?php
    $schemaJson = $block->getServicesSchemaJson();
    $fieldNameJs = $escaper->escapeJs($block->getElement()->getName());
    $deleteLabelJs = $escaper->escapeJs(__('Delete'));
    $htmlIdJs = $escaper->escapeJs($_htmlId);
    // Test Connection is only rendered for SAVED rows: the client factory reads
    // saved configuration, so unsaved rows cannot be tested. When multiple rows
    // share a service code, the factory uses the FIRST configured row of that
    // code, so results are effectively per-code, not per-row.
    $testUrlJs = $escaper->escapeJs($block->getUrl('mageos_ai/service/test'));
    $testLabelJs = $escaper->escapeJs(__('Test Connection'));
    $testingLabelJs = $escaper->escapeJs(__('Testing...'));
    // Refresh Models mirrors Test Connection: saved rows only, first configured row per
    // code; the button is rendered only for services whose schema opts in.
    $refreshUrlJs = $escaper->escapeJs($block->getUrl('mageos_ai/service/refreshmodels'));
    $refreshLabelJs = $escaper->escapeJs(__('Refresh Models'));
    $refreshingLabelJs = $escaper->escapeJs(__('Refreshing...'));
    $modelsLabelJs = $escaper->escapeJs(__('models'));
    $existingRowsJs = '';
    foreach ($block->getArrayRows() as $_row) {
        $rowData = $_row->getData();
        $serviceCode = array_key_first($rowData);
        $existingRowsJs .= sprintf(
            "    addRow('%s', %s, '%s');\n",
            $escaper->escapeJs($serviceCode),
            json_encode($rowData[$serviceCode]),
            $escaper->escapeJs((string) $_row->getData('_id'))
        );
    }
    $scriptString = <<<script
require(['prototype'], function () {
    const schema = {$schemaJson};
    const fieldNameBase = '{$fieldNameJs}';

    function escapeHtml(value) {
        if (value === null || value === undefined) return '';
        return String(value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function buildField(serviceCode, fieldName, field) {
        const base = fieldNameBase + '[' + fieldName + '][' + serviceCode + '][' + field.name + ']';
        if (field.type === 'select') {
            const options = field.options.map(function (opt) {
                const selected = (field.default === opt.value) ? ' selected' : '';
                return '<option value="' + escapeHtml(opt.value) + '"' + selected + '>'
                    + escapeHtml(opt.label) + '</option>';
            }).join('');
            return '<select name="' + escapeHtml(base) + '">' + options + '</select>';
        }
        const defaultAttr = field.default ? ' value="' + escapeHtml(field.default) + '"' : '';
        const inputType = (field.type === 'password' || field.type === 'text') ? field.type : 'text';
        const type = field.encrypted ? 'password' : inputType;
        return '<input type="' + type + '" name="' + escapeHtml(base) + '"' + defaultAttr + '/>';
    }

    function addRow(serviceCode, values, existingRowId) {
        const serviceSchema = schema[serviceCode];
        if (!serviceSchema) return;
        const fields = serviceSchema.fields;

        const d = new Date();
        const rowId = existingRowId || ('_' + d.getTime() + '_' + d.getMilliseconds());

        const rows = fields.map(function (field) {
            return '<tr>'
                + '<th>' + escapeHtml(field.label) + '</th>'
                + '<td>' + buildField(serviceCode, rowId, field) + '</td>'
                + '</tr>';
        }).join('');

        // Stored rows (they arrive with an existingRowId) get a Test Connection
        // button; unsaved rows cannot be tested because the client factory only
        // reads saved configuration.
        const refreshHtml = (existingRowId && serviceSchema.supportsModelRefresh)
            ? '<button class="action-secondary action-refresh-models" type="button"'
                + ' data-service-code="' + escapeHtml(serviceCode) + '"'
                + ' data-row-id="' + escapeHtml(rowId) + '">'
                + '<span>{$refreshLabelJs}</span></button>'
            : '';
        const testHtml = existingRowId
            ? '<button class="action-secondary action-test-connection" type="button"'
                + ' data-service-code="' + escapeHtml(serviceCode) + '">'
                + '<span>{$testLabelJs}</span></button>'
                + refreshHtml
                + '<span class="ai-test-result"></span>'
            : '';

        const rowHtml = '<tr id="' + rowId + '">'
            + '<td><table>' + rows + '</table></td>'
            + '<td class="col-actions">'
            + '<button class="action-delete" data-row-id="' + rowId + '" type="button">'
            + '<span>{$deleteLabelJs}</span></button>'
            + testHtml + '</td>'
            + '</tr>';

        Element.insert($('addRow{$htmlIdJs}'), { bottom: rowHtml });

        if (values) {
            Object.keys(values).forEach(function (key) {
                const selector = '[name="' + fieldNameBase + '[' + rowId + ']['
                    + serviceCode + '][' + key + ']"]';
                const el = document.querySelector(selector);
                if (!el) return;
                if (el.tagName === 'SELECT') {
                    const hasOption = Array.from(el.options).some(function (opt) {
                        return opt.value === values[key];
                    });
                    if (!hasOption && values[key] !== undefined && values[key] !== null && values[key] !== '') {
                        const legacyOpt = document.createElement('option');
                        legacyOpt.value = values[key];
                        legacyOpt.text = values[key] + ' (legacy)';
                        el.insertBefore(legacyOpt, el.firstChild);
                    }
                }
                el.value = values[key];
            });
        }
    }

    document.querySelectorAll('.ai-services-configurator .add-ai-service').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
            addRow(e.target.dataset.aiService);
        });
    });

    function testConnection(button) {
        const resultEl = button.parentNode.querySelector('.ai-test-result');
        button.disabled = true;
        resultEl.className = 'ai-test-result';
        resultEl.textContent = '{$testingLabelJs}';

        const body = new URLSearchParams();
        body.append('service_code', button.dataset.serviceCode);
        body.append('form_key', window.FORM_KEY);

        fetch('{$testUrlJs}', { method: 'POST', body: body })
            .then(function (response) { return response.json(); })
            .then(function (data) {
                if (data.success) {
                    resultEl.classList.add('ai-test-result-success');
                    resultEl.textContent = 'OK (' + data.latency_ms + 'ms): ' + data.response;
                } else {
                    resultEl.classList.add('ai-test-result-error');
                    resultEl.textContent = data.error;
                }
            })
            .catch(function (error) {
                resultEl.classList.add('ai-test-result-error');
                resultEl.textContent = String(error);
            })
            .finally(function () {
                button.disabled = false;
            });
    }

    function updateModelSelect(rowId, serviceCode, models) {
        const selector = '[name="' + fieldNameBase + '[' + rowId + ']['
            + serviceCode + '][model]"]';
        const el = document.querySelector(selector);
        if (!el || el.tagName !== 'SELECT') return;

        const current = el.value;
        while (el.options.length) {
            el.remove(0);
        }
        Object.keys(models).forEach(function (value) {
            const opt = document.createElement('option');
            opt.value = value;
            opt.text = models[value];
            el.appendChild(opt);
        });
        if (current !== '') {
            const hasOption = Array.from(el.options).some(function (opt) {
                return opt.value === current;
            });
            if (!hasOption) {
                const legacyOpt = document.createElement('option');
                legacyOpt.value = current;
                legacyOpt.text = current + ' (legacy)';
                el.insertBefore(legacyOpt, el.firstChild);
            }
            el.value = current;
        }
    }

    function refreshModels(button) {
        const resultEl = button.parentNode.querySelector('.ai-test-result');
        button.disabled = true;
        resultEl.className = 'ai-test-result';
        resultEl.textContent = '{$refreshingLabelJs}';

        const body = new URLSearchParams();
        body.append('service_code', button.dataset.serviceCode);
        body.append('form_key', window.FORM_KEY);

        fetch('{$refreshUrlJs}', { method: 'POST', body: body })
            .then(function (response) { return response.json(); })
            .then(function (data) {
                if (data.success) {
                    updateModelSelect(button.dataset.rowId, button.dataset.serviceCode, data.models);
                    resultEl.classList.add('ai-test-result-success');
                    resultEl.textContent = data.count + ' {$modelsLabelJs}';
                } else {
                    resultEl.classList.add('ai-test-result-error');
                    resultEl.textContent = data.error;
                }
            })
            .catch(function (error) {
                resultEl.classList.add('ai-test-result-error');
                resultEl.textContent = String(error);
            })
            .finally(function () {
                button.disabled = false;
            });
    }

    document.querySelector('.ai-services-configurator').addEventListener('click', function (e) {
        const testButton = e.target.closest('.action-test-connection');
        if (testButton) {
            testConnection(testButton);
            return;
        }
        const refreshButton = e.target.closest('.action-refresh-models');
        if (refreshButton) {
            refreshModels(refreshButton);
            return;
        }
        if (!e.target.classList.contains('action-delete')) return;
        document.getElementById(e.target.dataset.rowId).remove();
    });

{$existingRowsJs}});
script;
    ?>
    <?= /* @noEscape */ $secureRenderer->renderTag('script', [], $scriptString, false) ?>
</div>
